# ============================================================
# DOMUS - Variables de entorno
# Copia este archivo a .env.prod y rellena los valores
# ============================================================

# Base de datos
DB_USER=domus
DB_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
DB_NAME=domus_prod

# JWT
JWT_SECRET=GENERA_UNA_CLAVE_SECRETA_LARGA_Y_ALEATORIA

# URLs
FRONTEND_URL=https://domus.tudominio.com
REACT_APP_BACKEND_URL=https://domus.tudominio.com/api

# Puertos (opcionales, por defecto 3010/3011)
BACKEND_PORT=3010
FRONTEND_PORT=3011

# Admin inicial (se crea en la primera migración)
ADMIN_EMAIL=admin@domus.local
ADMIN_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
ADMIN_NAME=Admin